# HotPlace MVP — environment variables
#
# 현재 MVP는 100% 브라우저 localStorage 기반으로 동작한다.
# 배포에 필요한 환경변수가 없다 — Supabase / OpenAI / 지도 API 미연결이라
# 유료 API 키도 필요 없다. Vercel에서 그냥 import 후 Deploy하면 된다.
#
# 아래는 나중에 각 기능을 붙일 때 사용할 변수 예시다. (지금은 설정 불필요)
# 실제로 쓸 때 이 파일을 복사해 .env.local 로 만들고 값을 채운다.

# --- (예정) Supabase 연결 시 ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- (예정) OpenAI 실제 AI 코스 추천 연동 시 (서버 전용, 클라이언트 노출 금지) ---
# OPENAI_API_KEY=

# 참고: 피드백 Google Form 링크는 환경변수가 아니라
# src/lib/config.ts 의 FEEDBACK_FORM_URL 상수로 관리한다.
