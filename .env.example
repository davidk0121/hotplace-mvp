# HotPlace MVP — environment variables
#
# 데이터는 여전히 100% 브라우저 localStorage에 저장된다 (Supabase 미연결).
# 아래 MapTiler 키만 설정하면 실제 지도가 켜지고, 없으면 목업 지도로 폴백한다.
# 로컬에서 쓸 때는 이 파일을 복사해 .env.local 로 만들고 값을 채운다.

# --- 실제 지도 (MapLibre + MapTiler, 무료 티어) ---
# 1) https://cloud.maptiler.com 가입 (무료)
# 2) Account → API keys 에서 키 복사
# 3) 아래에 붙여넣기 (로컬은 .env.local, 배포는 Vercel 환경변수)
# 4) MapTiler 대시보드에서 이 키의 허용 Origin(도메인)을 제한하는 것을 권장
#    (NEXT_PUBLIC_ 값은 클라이언트에 노출되기 때문)
# 키가 없으면 앱은 깨지지 않고 기존 미리보기(목업) 지도로 동작한다.
NEXT_PUBLIC_MAPTILER_KEY=

# --- (예정) Supabase 연결 시 ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- (예정) OpenAI 실제 AI 코스 추천 연동 시 (서버 전용, 클라이언트 노출 금지) ---
# OPENAI_API_KEY=

# 참고: 피드백 Google Form 링크는 환경변수가 아니라
# src/lib/config.ts 의 FEEDBACK_FORM_URL 상수로 관리한다.
